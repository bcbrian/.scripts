# CUSTOMIZATION FOR ZSH
# if [ -r /c/Users/brian/.scripts/zsh/.myzshrc ]; then
#     source /c/Users/brian/.scripts/zsh/.myzshrc
# fi
# Store original directory before changing to root
ORIGINAL_DIR=$(pwd)
cd ~        

# logo (skip when SKIP_LOGO=1, e.g. during update/setup)
[[ -z "$SKIP_LOGO" ]] && sh -c "$(curl -fsSL https://scripts.codesagas.dev/setup/logo.sh)"

# Auto-update .scripts once per 24hrs (throttle file is gitignored, local to each machine)
LAST_PULL_FILE="$HOME/.scripts/.last-auto-pull"
if [[ -d "$HOME/.scripts/.git" ]]; then
  DO_PULL=0
  if [[ ! -f "$LAST_PULL_FILE" ]]; then
    DO_PULL=1
  else
    LAST=$(cat "$LAST_PULL_FILE" 2>/dev/null)
    NOW=$(date +%s)
    [[ -n "$LAST" ]] && (( NOW - LAST > 86400 )) && DO_PULL=1
  fi
  if (( DO_PULL )); then
    (cd "$HOME/.scripts" && git pull --rebase 2>/dev/null && echo "$(date +%s)" > "$LAST_PULL_FILE") &
  fi
fi

# NVM
alias oldvim="/usr/bin/vim"
alias vimdiff='nvim -d'
export GIT_EDITOR=nvim
alias vim="nvim"
alias vi="nvim"

# Example aliases
alias scripts="vim ~/.scripts"
alias config="vim ~/.scripts/zsh/.myzshrc"
alias reset="source ~/.zshrc"
alias update="bash ~/.scripts/setup/update.sh"
alias configzsh="vim ~/.zshrc"
alias ohmyzsh="vim ~/.oh-my-zsh"
alias vimrc="cd ~/.scripts && vim ~/.scripts/nvim"

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

if nvm which default &>/dev/null; then
    nvm use default
else
    nvm install --lts --default
fi

# Bun
export BUN_INSTALL="$HOME/.bun"
[[ ":$PATH:" != *":$BUN_INSTALL/bin:"* ]] && export PATH="$BUN_INSTALL/bin:$PATH"
[ -s "$BUN_INSTALL/_bun" ] && source "$BUN_INSTALL/_bun"

# NVIM things (and Cursor Agent CLI)
[[ ":$PATH:" != *":$HOME/.local/bin:"* ]] && export PATH="$HOME/.local/bin:$PATH"
export npm_config_user=root
export NPM_CONFIG_USER=root

cd "$ORIGINAL_DIR"
